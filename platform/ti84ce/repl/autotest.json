{
    "_comment": [
        "Run with: cemu-autotester autotest.json (set AUTOTESTER_ROM to your ROM).",
        "This sequence types Asm(prgmMLUA, which only works on OS <= 5.4 ROMs;",
        "TI removed assembly execution in OS 5.5+. On newer ROMs use",
        "autotest-cesium.json (requires the Cesium shell installed as an app).",
        "Flow: run the transferred SMOKELUA source appvar (compiled on-calc,",
        "hash 1), then open the REPL with mode and type print(2+3) (hash 2).",
        "Run tools/get_clibs.py once to fetch test/clibs (LibLoad + graphx)."
    ],
    "rom": "84ce.rom",
    "transfer_files": [
        "bin/MLUA.8xp",
        "test/SMOKELUA.8xv",
        "test/clibs/libload.8xv",
        "test/clibs/graphx.8xv"
    ],
    "target": {
        "name": "MLUA",
        "isASM": true
    },
    "sequence": [
        "action|launch",
        "delay|3000",
        "key|enter",
        "delay|5000",
        "hashWait|1",
        "key|enter",
        "delay|1500",
        "key|mode",
        "delay|2000",
        "key|alpha",
        "key|8",
        "key|alpha",
        "key|mul",
        "key|alpha",
        "key|sq",
        "key|alpha",
        "key|log",
        "key|alpha",
        "key|4",
        "key|(",
        "key|2",
        "key|+",
        "key|3",
        "key|)",
        "delay|500",
        "key|enter",
        "delay|2500",
        "hashWait|2",
        "key|clear",
        "delay|500",
        "key|clear"
    ],
    "hashes": {
        "1": {
            "description": "SMOKELUA source compiled and run on-calc",
            "start": "vram_start",
            "size": "vram_16_size",
            "expected_CRCs": [
                "91375720"
            ],
            "timeout": 10000
        },
        "2": {
            "description": "REPL evaluated print(2+3)",
            "start": "vram_start",
            "size": "vram_16_size",
            "expected_CRCs": [
                "C403FD24"
            ],
            "timeout": 10000
        }
    }
}
